# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Security ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ─── Database ─────────────────────────────────────────────
DATABASE_PATH=./data/msaadafund.db
# For PostgreSQL (production), set DATABASE_URL instead:
# DATABASE_URL=postgresql://user:password@host:5432/msaadafund

# ─── AzamPay (Primary Payment Aggregator — Tanzania) ──────
# Sign up at: https://developers.azampay.co.tz
AZAMPAY_APP_NAME=MsaadaFund
AZAMPAY_CLIENT_ID=your_azampay_client_id
AZAMPAY_CLIENT_SECRET=your_azampay_client_secret
AZAMPAY_BASE_URL=https://sandbox.azampay.co.tz
# Production: https://api.azampay.co.tz

# ─── Africa's Talking (SMS — OTP & Notifications) ─────────
# Sign up at: https://account.africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key
AT_SENDER_ID=MsaadaFund
# Production: set AT_USERNAME to your actual username

# ─── File Uploads ─────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=5

# ─── App Config ───────────────────────────────────────────
APP_NAME=MsaadaFund
APP_URL=https://msaadafund.co.tz
ADMIN_PHONE=255712000000
OTP_EXPIRY_MINUTES=10
PLATFORM_FEE_PERCENT=2.5
